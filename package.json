{
    "name": "blog",
    "version": "0.0.1",
    "description": "A blog–including a back-end api, a client view, and an admin view–built as part of The Odin Project project",
    "workspaces": [
        "apps/blog-api",
        "apps/blog-admin",
        "apps/blog-public",
        "packages/shared"
    ],
    "scripts": {
        "test": "conc 'npm run test --workspace=blog-api'",
        "dev": "conc 'npm run dev --workspace=blog-api' 'npm run dev --workspace=blog-public' 'npm run dev --workspace=blog-admin'",
        "build": "conc 'npm run build --workspace=blog-admin' 'npm run build --workspace=blog-public'"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cobbland/blog.git"
    },
    "keywords": [],
    "author": "",
    "license": "GPL-3.0-only",
    "type": "commonjs",
    "bugs": {
        "url": "https://github.com/cobbland/blog/issues"
    },
    "homepage": "https://github.com/cobbland/blog#readme",
    "devDependencies": {
        "concurrently": "^9.2.1",
        "jest": "^30.4.2"
    }
}
